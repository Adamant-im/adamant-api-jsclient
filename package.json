{
  "name": "adamant-api",
  "version": "2.4.0",
  "description": "Modular TypeScript SDK for the ADAMANT blockchain and deterministic wallet helpers",
  "keywords": [
    "adm",
    "adamant",
    "blockchain",
    "messenger",
    "chat",
    "decentralized messenger",
    "anonymous messenger",
    "secure messenger",
    "wallet",
    "crypto wallet",
    "private keys",
    "communication",
    "decentralized",
    "decentralization",
    "anonymous",
    "anonymity",
    "secure",
    "encrypted",
    "encryption",
    "crypto",
    "cryptocurrency",
    "bitcoin",
    "ethereum"
  ],
  "homepage": "https://github.com/Adamant-im/adamant-api-jsclient#readme",
  "bugs": {
    "url": "https://github.com/Adamant-im/adamant-api-jsclient/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Adamant-im/adamant-api-jsclient.git"
  },
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=22"
  },
  "license": "GPL-3.0",
  "author": "ADAMANT Foundation <devs@adamant.im> (https://adamant.im)",
  "main": "dist/index.js",
  "src": "src/index.ts",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./adm": {
      "types": "./dist/adm/index.d.ts",
      "default": "./dist/adm/index.js"
    },
    "./api": {
      "types": "./dist/api/index.d.ts",
      "default": "./dist/api/index.js"
    },
    "./transactions": {
      "types": "./dist/helpers/transactions/index.d.ts",
      "default": "./dist/helpers/transactions/index.js"
    },
    "./metadata": {
      "types": "./dist/metadata/index.d.ts",
      "default": "./dist/metadata/index.js"
    },
    "./coins/btc": {
      "types": "./dist/coins/btc.d.ts",
      "default": "./dist/coins/btc.js"
    },
    "./coins/eth": {
      "types": "./dist/coins/eth.d.ts",
      "default": "./dist/coins/eth.js"
    },
    "./coins/dash": {
      "types": "./dist/coins/dash.d.ts",
      "default": "./dist/coins/dash.js"
    },
    "./coins/doge": {
      "types": "./dist/coins/doge.d.ts",
      "default": "./dist/coins/doge.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/",
    "types/"
  ],
  "scripts": {
    "test": "node scripts/run-tests.mjs",
    "test:package": "node scripts/test-package.mjs",
    "lint": "gts lint",
    "prepare": "husky",
    "clean": "node -e \"require('fs').rmSync('dist', {recursive: true, force: true})\"",
    "compile": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json && tsc -p scripts/package-test/tsconfig.json",
    "build": "npm run clean && npm run compile",
    "fix": "gts fix",
    "api-types:sync": "node scripts/sync-api-types.mjs",
    "api-types:check": "node scripts/sync-api-types.mjs --check",
    "metadata:sync": "node scripts/sync-wallet-metadata.mjs",
    "metadata:check": "node scripts/sync-wallet-metadata.mjs --check",
    "pretest": "npm run build && npm run typecheck",
    "posttest": "npm run lint",
    "prepack": "npm run build"
  },
  "dependencies": {
    "axios": "^1.18.0",
    "bignumber.js": "^11.1.4",
    "bip32": "^5.0.1",
    "bip39": "^3.1.0",
    "bitcoinjs-lib": "^7.0.1",
    "bytebuffer": "^5.0.1",
    "coininfo": "^5.2.1",
    "ecpair": "^3.0.1",
    "ed2curve": "^0.3.0",
    "ethereum-cryptography": "^3.2.0",
    "pbkdf2": "^3.1.6",
    "socket.io-client": "^4.8.3",
    "sodium-browserify-tweetnacl": "^0.2.6",
    "tiny-secp256k1": "^2.2.4",
    "tweetnacl": "^1.0.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@redocly/cli": "2.34.0",
    "@types/bytebuffer": "^5.0.49",
    "@types/ed2curve": "^0.2.4",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.0.0",
    "@types/pbkdf2": "^3.1.2",
    "eslint": "10.5.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "prettier": "3.8.4",
    "swagger-typescript-api": "13.12.2",
    "ts-jest": "^29.4.11",
    "gts": "^7.0.0",
    "typescript": "~6.0.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
