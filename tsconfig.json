{
  "compilerOptions": {
    "strict": true,
    "lib": [],
    "target": "ESNext",
    "module": "CommonJS",
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["node", "jest"],
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts", "src/**/*.json", "types/*.d.ts"],
  "exclude": ["node_modules", "src/**/tests/**"]
}
