{
  "compilerOptions": {
    "strict": true,
    "lib": [],
    "target": "ESNext",
    "module": "CommonJS",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["node", "jest"],
    "skipLibCheck": true,
    "noEmit": true,
    "rootDir": "."
  },
  "include": ["src/**/*.ts", "src/**/*.json", "examples/**/*.mts", "types/*.d.ts"],
  "exclude": ["node_modules", "dist"]
}
